# CurrencyExchanger

###
# @name currencies
GET http://localhost:8080/currencies

###
# @name currency
GET http://localhost:8080/currency/EUR

###
# @name exchangeRates
GET http://localhost:8080/exchangeRates

###
# @name exchangeRates200
POST http://localhost:8080/exchangeRates
Content-Type: application/x-www-form-urlencoded

baseCurrencyCode = AFN &
targetCurrencyCode = AOA &
rate = 0.1

###
# @name currencies
POST http://localhost:8080/currencies
Content-Type: application/x-www-form-urlencoded

name = "AAB name" &
code = AAB &
sign = A

###
# @name updateExchangeRate
PATCH http://localhost:8080/exchangeRate/AFNALL
Content-Type: application/x-www-form-urlencoded

rate = 6

###
# @name exchange
GET http://localhost:8080/exchange?
    from=AFN&
    to=ALL&
    amount=10
Content-Type: application/x-www-form-urlencoded

rate = 6

###
# @name getConcreteExchangeRate
GET http://localhost:8080/exchangeRate/AFNALL
Content-Type: application/x-www-form-urlencoded

rate = 6
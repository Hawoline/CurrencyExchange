# CurrencyExchanger

###
# @name currencies
GET http://localhost:8080/currencies

###
# @name currency
GET http://localhost:8080/currency/ASD

###
# @name currencies
POST http://localhost:8080/currencies
Content-Type: application/x-www-form-urlencoded

name = "AAB name" &
code = AAB &
sign = A

###
# @name getAllExchangeRates
GET http://localhost:8080/exchangeRates

###
# @name addExchangeRate
POST http://localhost:8080/exchangeRates
Content-Type: application/x-www-form-urlencoded

baseCurrencyCode = EUR &
targetCurrencyCode = AOD &
rate = 0.2

###
# @name getConcreteExchangeRate
GET http://localhost:8080/exchangeRate/AFNALL
Content-Type: application/x-www-form-urlencoded

rate = 6

###
# @name updateExchangeRate
PATCH http://localhost:8080/exchangeRate/EURAOD
Content-Type: application/x-www-form-urlencoded

rate = 8

###
# @name exchange
GET http://localhost:8080/exchange?
    from=AFN&
    to=ALL&
    amount=10
Content-Type: application/x-www-form-urlencoded

rate = 6
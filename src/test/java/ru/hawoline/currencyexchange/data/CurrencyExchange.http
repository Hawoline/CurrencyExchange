# CurrencyExchanger

###
# @name currencies
GET http://localhost:8080/currencies

###
# @name currency
GET http://localhost:8080/currency/AFN

###
# @name currencyNotFound
GET http://localhost:8080/currency/AAA

###
# @name currencyCodeContainsDigits
GET http://localhost:8080/currency/123

###
# @name invalidCurrencyCodeLength
GET http://localhost:8080/currency/AAAA

###
# @name invalidCurrencyCodeLength
GET http://localhost:8080/currency/AA

###
# @name currencies
POST http://localhost:8080/currencies
Content-Type: application/x-www-form-urlencoded

name = "AAB name" &
code = AAB &
sign = A

###
# @name getAllExchangeRates
GET http://185.242.107.137:8080/CurrencyExchange-1.0-SNAPSHOT/exchangeRates

###
# @name addExchangeRate
POST http://localhost:8080/exchangeRates
Content-Type: application/x-www-form-urlencoded

baseCurrencyCode = EUR &
targetCurrencyCode = AOD &
rate = 0.2

###
# @name getConcreteExchangeRate
GET http://localhost:8080/exchangeRate/ALLDZD
Content-Type: application/x-www-form-urlencoded

rate = 6

###
# @name updateExchangeRate
PATCH http://localhost:8080/exchangeRate/EURAOD
Content-Type: application/x-www-form-urlencoded

rate = 8

###
# @name exchangeDirectRate
GET http://localhost:8080/exchange?
    from=AFN&
    to=ALL&
    amount=10
Content-Type: application/x-www-form-urlencoded

rate = 6

###
# @name exhangeReverseRate
GET http://localhost:8080/exchange?
    from=ALL&
    to=AFN&
    amount=10
Content-Type: application/x-www-form-urlencoded

###
# @name exhangeCrossDirectRate
GET http://localhost:8080/exchange?
    from=ALL&
    to=EUR&
    amount=10
Content-Type: application/x-www-form-urlencoded
###
# @name exhangeCrossRateWhereDollarInTargets
GET http://localhost:8080/exchange?
    from=ALL&
    to=AUD&
    amount=5
Content-Type: application/x-www-form-urlencoded
###
# @name exhangeCrossRateWhereDollarInBases
GET http://localhost:8080/exchange?
    from=DZD&
    to=AWG&
    amount=5
Content-Type: application/x-www-form-urlencoded